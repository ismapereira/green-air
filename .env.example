# Green Air - Variáveis de ambiente
# Copie para .env e preencha com seus valores

# Ambiente (development, production)
APP_ENV=development

# Banco de dados
DB_HOST=localhost
DB_NAME=green_air
DB_USER=root
DB_PASS=

# OpenWeather API - https://openweathermap.org/api
OPENWEATHER_API_KEY=sua_chave_aqui
OPENWEATHER_CITY=São Paulo

# Configuração de E-mail (SMTP) — necessário para recuperação de senha
# Para Gmail: ative "App Passwords" em https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app
MAIL_FROM_ADDRESS=seu_email@gmail.com
MAIL_FROM_NAME=Green Air
MAIL_ENCRYPTION=tls

# Google reCAPTCHA v2 Invisible — obtenha as chaves em https://www.google.com/recaptcha/admin
# Deixe vazio para desativar a verificação CAPTCHA nos formulários
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
